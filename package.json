{
  "name": "inmosignal",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @repo/database prisma generate",
    "db:migrate": "pnpm --filter @repo/database prisma migrate dev",
    "db:studio": "pnpm --filter @repo/database prisma studio"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
