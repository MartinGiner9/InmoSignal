{
  "name": "inmosignal",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo dev --filter=web --filter=api",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @repo/database prisma generate",
    "db:migrate": "pnpm --filter @repo/database prisma migrate dev",
    "db:studio": "pnpm --filter @repo/database prisma studio",
    "dev:all": "turbo dev",
    "dev:workers": "pnpm --filter workers dev",
    "infra": "docker compose up -d postgres",
    "infra:all": "docker compose --profile redis up -d",
    "infra:down": "docker compose down",
    "infra:redis": "docker compose up -d redis",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:web:alt": "pnpm --filter web dev:alt"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
